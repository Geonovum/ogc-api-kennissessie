meta {
  name: Exec add async copy
  type: http
  seq: 9
}

post {
  url: {{serviceHost}}/processes/add/execution
  body: json
  auth: inherit
}

headers {
  Prefer: respond-async
}

body:json {
  {
    "inputs": {
      "number1": 19,
      "number2": 7
    },
    "subscriber": {
      "successUri": ":serviceUrl/callback/:jobId?type=success",
      "inProgressUri": ":serviceUrl/callback/:jobId?type=inProgress",
      "failedUri": ":serviceUrl/callback/:jobId?type=failed"
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
