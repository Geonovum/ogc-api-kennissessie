{
  "id": "reverse",
  "title": "Reverse 2 numbers",
  "description": "Reverses the 2 provided numbers. Either sync or async.",
  "version": "0.0.1",
  "jobControlOptions": ["sync-execute"],
  "outputTransmission": ["value"],
  "inputs": {
    "number1": {
      "title": "Number 1 Literal Input",
      "description": "A number literal input.",
      "schema": {
        "type": "number",
        "format": "integer"
      }
    },
    "number2": {
      "title": "Number 2 Literal Input",
      "description": "A number literal input.",
      "schema": {
        "type": "number",
        "format": "integer"
      }
    }
  },
  "outputs": {
    "number1": {
      "id": "Result",
      "title": "Was number 2",
      "description": "A number literal output.",
      "schema": {
        "type": "number",
        "format": "integer"
      }
    },
    "number2": {
      "id": "Result",
      "title": "Was number 1",
      "description": "A number literal output.",
      "schema": {
        "type": "number",
        "format": "integer"
      }
    }
  }
}
